<Window x:Class="PieceSolver.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PieceSolver" Height="250" Width="430" Background="#252526"
        ResizeMode="NoResize" ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="22">
        <TextBlock Text="PieceSolver" Foreground="#E0E0E8" FontSize="20" FontWeight="Bold" />
        <TextBlock x:Name="VersionText" Text="version …" Foreground="#7A7A88" FontSize="11" Margin="0,3,0,0" />
        <TextBlock Text="In-process developability-flow studio for CreaseMachine."
                   Foreground="#C8C8C8" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
        <TextBlock Text="Flows a triangle mesh toward a piecewise-developable (creasable) sheet using the covariance developability energy of Stein, Grinspun &amp; Crane (2018)."
                   Foreground="#9090A0" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />
        <TextBlock Text="GPL-v2  ·  vendored Plankton (LGPL)"
                   Foreground="#7A7A88" FontSize="11" Margin="0,14,0,0" />
        <Button x:Name="CloseButton" Content="Close" Width="84" Padding="0,4"
                HorizontalAlignment="Right" Margin="0,18,0,0" />
    </StackPanel>
</Window>
