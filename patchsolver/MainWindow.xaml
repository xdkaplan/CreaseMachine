<Window x:Class="CreasePatchSolver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CreasePatchSolver"
        Title="CreasePatchSolver" Height="700" Width="1000"
        Background="#1E1E1E">
    <Window.Resources>
        <!-- Reusable: remaps a slider's value within [min,max] to a 0-100% readout. -->
        <local:RangeToPercentConverter x:Key="RangeToPercent" />
        <!-- Shows a fraction directly as a percent (value × 100), allowing >100% (e.g. deCraze to 300%). -->
        <local:FractionToPercentConverter x:Key="FractionToPercent" />
        <!-- sidebar-collapse glyph (from sidebar-collapse.svg, 800x800); evenodd (F0). Mirrored
             with ScaleX=-1 for the right panel. -->
        <!-- Dark, flat tab headers (the default WPF TabItem renders light/3D, clashing with the
             hand-styled dark panels). Implicit style -> applies to every TabItem in the window. -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#8A8A98" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="hdr" Padding="9,4" Margin="0,0,2,0" Background="Transparent"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="hdr" Property="BorderBrush" Value="#6A9FE0" />
                                <Setter Property="Foreground" Value="#E0E0E8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C8C8D0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark menu items (the default WPF menu renders light, clashing with the dark chrome). -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#C8C8C8" />
            <Setter Property="Background" Value="#2D2D30" />
        </Style>

        <Geometry x:Key="CollapseIcon">F0 m375.35 316.42l-82.33 82.33 82.33 82.34c4.97 4.62 7.84 11.06 7.96 17.85 0.12 6.78-2.52 13.32-7.32 18.11-4.8 4.8-11.34 7.44-18.12 7.32-6.78-0.12-13.22-2.99-17.85-7.95l-100-100c-2.32-2.32-4.16-5.08-5.41-8.11-1.25-3.03-1.9-6.28-1.9-9.56 0-3.28 0.65-6.53 1.9-9.56 1.25-3.03 3.09-5.78 5.41-8.1l100-100c4.74-4.42 11.01-6.82 17.49-6.71 6.47 0.11 12.65 2.74 17.23 7.32 4.58 4.58 7.21 10.76 7.32 17.24 0.11 6.47-2.29 12.74-6.71 17.48z m125 66.67c-7.66 0-15.25 1.51-22.32 4.44-7.08 2.93-13.51 7.23-18.93 12.64-5.41 5.42-9.71 11.85-12.64 18.93-2.93 7.07-4.44 14.66-4.44 22.32v550c0 32.2 26.13 58.33 58.33 58.33h550c7.66 0 15.25-1.51 22.32-4.44 7.08-2.93 13.51-7.23 18.93-12.64 5.41-5.42 9.71-11.85 12.64-18.93 2.93-7.07 4.44-14.66 4.44-22.32v-550c0-7.66-1.51-15.25-4.44-22.32-2.93-7.08-7.23-13.51-12.64-18.93-5.42-5.41-11.85-9.71-18.93-12.64-7.07-2.93-14.66-4.44-22.32-4.44zm-8.33 58.33q0-1.66 0.63-3.19 0.64-1.53 1.81-2.7 1.17-1.17 2.7-1.81 1.53-0.63 3.19-0.63h375v566.66h-375q-1.66 0-3.19-0.63-1.53-0.64-2.7-1.81-1.17-1.17-1.81-2.7-0.63-1.53-0.63-3.19zm433.33 558.33v-566.66h125q1.66 0 3.19 0.63 1.53 0.64 2.7 1.81 1.17 1.17 1.81 2.7 0.63 1.53 0.63 3.19v550q0 1.66-0.63 3.19-0.64 1.53-1.81 2.7-1.17 1.17-2.7 1.81-1.53 0.63-3.19 0.63z</Geometry>
    </Window.Resources>
    <!-- Standard 4-panel docked chrome: Windows-style menu bar, fixed top/bottom bars, drag-resizable
         + collapsible left/right panels (chevron + drag-below-32px), center hosts the GL viewport. -->
    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- MENU bar (Windows-style). Shortcuts shown via InputGestureText are bound in code-behind. -->
        <Menu Grid.Row="0" Background="#2D2D30" Foreground="#C8C8C8" Padding="2,1">
            <MenuItem Header="_File">
                <MenuItem x:Name="MenuSaveAs" Header="Save Session _As…" InputGestureText="Ctrl+S" />
            </MenuItem>
            <MenuItem Header="_Window">
                <MenuItem x:Name="MenuConsole" Header="_Console" IsCheckable="True" InputGestureText="Ctrl+Shift+J" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem x:Name="MenuAbout" Header="_About" />
            </MenuItem>
        </Menu>

        <!-- TOP bar (full width, 32px) -->
        <Border Grid.Row="1" Background="#2D2D30">
            <DockPanel LastChildFill="False" Margin="8,0">
                <TextBlock DockPanel.Dock="Left" Text="CreasePatchSolver" Foreground="#C8C8C8"
                           VerticalAlignment="Center" FontSize="12" />
                <!-- Right-docked: first declared sits rightmost. Layout L->R: Reset | SubD | Solve. -->
                <Button x:Name="SolveButton" DockPanel.Dock="Right" Content="Solve"
                        Padding="16,2" Margin="4,0,0,0" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"
                        ToolTip="Bake: develop to the selected Accuracy, then for each Subdivision level subdivide and re-develop. Runs to completion (no live animation), then shows the result." />
                <Button x:Name="SubdivideButton" DockPanel.Dock="Right" Content="SubD"
                        Padding="10,2" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center"
                        ToolTip="One 1-to-4 subdivision (refine, then keep flowing)" />
                <Button x:Name="ResetButton" DockPanel.Dock="Right" Content="Reset"
                        Padding="10,2" FontSize="12" VerticalAlignment="Center"
                        ToolTip="Reload the input mesh and reset the flow" />
            </DockPanel>
        </Border>

        <!-- MIDDLE row: left panel | splitter | center | splitter | right panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftCol" Width="220" MinWidth="26" />
                <ColumnDefinition x:Name="LeftSplitCol" Width="6" />
                <ColumnDefinition Width="*" MinWidth="120" />
                <ColumnDefinition x:Name="RightSplitCol" Width="6" />
                <ColumnDefinition x:Name="RightCol" Width="240" MinWidth="26" />
            </Grid.ColumnDefinitions>

            <!-- LEFT panel: placeholder (the session log now lives in the toggleable Console window;
                 Window > Console or Ctrl+Shift+J). Collapse chevron at the top-RIGHT (inner) corner. -->
            <Border Grid.Column="0" Background="#252526" ClipToBounds="True">
                <Grid>
                    <Button x:Name="LeftCollapseBtn" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Width="24" Height="24" Margin="0,4,4,0" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" ToolTip="Collapse / expand panel">
                        <Viewbox Width="15" Height="15">
                            <Path Data="{StaticResource CollapseIcon}" Fill="#A0A6AE" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <!-- LEFT splitter (drag to resize, click to collapse/expand) -->
            <GridSplitter x:Name="LeftSplitter" Grid.Column="1" Width="6"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#3F3F46" ShowsPreview="False"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" />

            <!-- CENTER region: GL viewport gets injected here in code-behind -->
            <Grid x:Name="CenterHost" Grid.Column="2" Background="#1A1A1C" ClipToBounds="True" />

            <!-- RIGHT splitter (drag to resize, click to collapse/expand) -->
            <GridSplitter x:Name="RightSplitter" Grid.Column="3" Width="6"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#3F3F46" ShowsPreview="False"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" />

            <!-- RIGHT panel: SIMULATION / DISPLAY tabs (bound to SimSettings view-model). Collapse
                 chevron sits in its own thin strip at the top-LEFT (inner) corner, icon mirrored;
                 the tab strip + content fill the rest. -->
            <Border Grid.Column="4" Background="#2A2A2E" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- chevron strip -->
                    <Button x:Name="RightCollapseBtn" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top"
                            Width="24" Height="24" Margin="4,2,0,0" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" ToolTip="Collapse / expand panel">
                        <Viewbox Width="15" Height="15">
                            <Path Data="{StaticResource CollapseIcon}" Fill="#A0A6AE"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleX="-1" />
                                </Path.RenderTransform>
                            </Path>
                        </Viewbox>
                    </Button>

                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0">
                        <TabItem Header="SIMULATION">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,8">
                                <StackPanel Margin="10,0,10,0">
                                    <!-- Mesh picker: 1..30 -> NURBS test surfaces 0.stl..29.stl. Changing this
                                         resets the app to that mesh (load + clear flat + re-arm BFF). -->
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Mesh" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Pick a NURBS test surface (1-30). Switching resets the solver to that mesh." />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding MeshIndex}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="1" Maximum="30" Value="{Binding MeshIndex}" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Subdiv" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Subdivision level: how many 1->4 refine rounds Solve does (develop to accuracy, then subdivide + re-develop, per level). 0 = no subdivision." />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding SubdivLevel}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="4" Value="{Binding SubdivLevel}" IsSnapToTickEnabled="True" TickFrequency="1" TickPlacement="BottomRight" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <!-- GO workflow: Accuracy (material) + Tolerance (fit-up mm) up top; raw solver
                                         terms fold under Advanced. Startup config = preset D (single developable). -->
                                    <DockPanel Margin="0,8,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Accuracy" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="How developable it must be, by material: Fabric (stretchy) -> Paper -> Sheet Metal -> Plate Metal (stiff, near-perfect). Sets the allowable in-plane strain." />
                                        <TextBlock DockPanel.Dock="Right" Width="80" Text="{Binding AccuracyLabel}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="3" Value="{Binding AccuracyLevel}" IsSnapToTickEnabled="True" TickFrequency="1" TickPlacement="BottomRight" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                    <DockPanel Margin="0,2,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Strain" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Live in-plane strain (relative edge-length error = developability). GO when it is within the selected material's allowable strain." />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding GoText}" Foreground="{Binding GoBrush}" FontSize="11" FontWeight="Bold" Width="80" TextAlignment="Right" VerticalAlignment="Center" Margin="6,0" />
                                        <TextBlock Text="{Binding StrainText}" Foreground="#8A8A98" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Tolerance" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Absolute fit-up tolerance (gap between adjacent panels at assembly). Used later for panel sizing / acceptance." />
                                        <TextBlock DockPanel.Dock="Right" Width="80" Text="{Binding ToleranceMm, StringFormat={}{0:0.##} mm}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="10" Value="{Binding ToleranceIndex}" IsSnapToTickEnabled="True" TickFrequency="1" TickPlacement="BottomRight" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                    <DockPanel Margin="0,6,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="" Width="62" />
                                        <CheckBox Content="Show rulings (developable generators)" IsChecked="{Binding ShowRulings, Mode=TwoWay}" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" Margin="6,0"
                                                  ToolTip="Overlay per-vertex ruling lines — the zero-curvature straight generators (gold). Clean parallel rulings = genuinely developable; swirling = not there yet." />
                                    </DockPanel>

                                    <Expander Header="Advanced" IsExpanded="False" Foreground="#9AA0A8" FontSize="11" Margin="0,10,0,0">
                                        <StackPanel Margin="0,6,0,0">
                                            <DockPanel Margin="0,0,0,2">
                                                <TextBlock DockPanel.Dock="Left" Text="Preset" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                           ToolTip="Raw developability presets. A scale-pin only · B +anchor (low-drift) · C +differential bending (faithful+smooth) · D no-anchor+plain-bending (single entirely-developable patch = the default)." />
                                                <StackPanel Orientation="Horizontal">
                                                    <Button x:Name="PresetAButton" Content="A" Width="30" Margin="2,0" FontSize="11" ToolTip="A — scale-pin only (wrinkly, more drift)" />
                                                    <Button x:Name="PresetBButton" Content="B" Width="30" Margin="2,0" FontSize="11" ToolTip="B — low-drift: + small anchor" />
                                                    <Button x:Name="PresetCButton" Content="C" Width="30" Margin="2,0" FontSize="11" ToolTip="C — low-drift + smooth: anchor + differential bending" />
                                                    <Button x:Name="PresetDButton" Content="D" Width="30" Margin="2,0" FontSize="11" ToolTip="D — single entirely-developable patch (no anchor + plain bending) = the default" />
                                                </StackPanel>
                                            </DockPanel>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Iso" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Developability driver (gain): weight on equalizing corresponding edge lengths between M and the flat M'. LM is stable at any value — crank it freely." />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding IsoWeight, StringFormat=0.##}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="50" Value="{Binding IsoWeight}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Fair" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Fairness/smoothing weight. With 'Differential' (below) ON it de-buckles without shrinking (preserves original detail) — the C preset. OFF it's a plain Laplacian (shrinks); leave low or 0." />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding FairWeight, StringFormat=0.##}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="1" Value="{Binding FairWeight}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                    <DockPanel Margin="0,1,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="" Width="62" />
                                        <CheckBox Content="Differential (non-shrinking)" IsChecked="{Binding DiffFair, Mode=TwoWay}" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" Margin="6,0"
                                                  ToolTip="Fair mode. On: penalize the CHANGE in local shape from the original (non-shrinking, preserves detail). Off: plain Laplacian (shrinks)." />
                                    </DockPanel>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Anchor" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Faithfulness dial: weight holding M near its original shape. Lower toward 0 to drive relErr -> ~0 (more deformation); raise to stay faithful. Without any anchor M can collapse flat onto M'." />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding AnchorWeight, StringFormat=0.##}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="2" Value="{Binding AnchorWeight}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Bend" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="2nd-order bending (differential bi-Laplacian) — the ANTI-WRINKLE term (paper's 2nd-difference fairness, triangle analog). Penalises change in curvature from the original, flattening buckles WITHOUT shrinking. Raise to de-wrinkle (preset C uses 0.6); very high slightly fights developability." />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding BendWeight, StringFormat=0.##}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="3" Value="{Binding BendWeight}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Scale" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Global scale pin (anti-collapse): pins total size to the original so M can't shrink flat. This single global term is all that's needed in place of a dense Anchor — with Scale on, Anchor can be 0 and M still develops to relErr ~0." />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding ScaleWeight, StringFormat=0.##}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="50" Value="{Binding ScaleWeight}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Smoother" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Non-shrinking smoother applied after each LM step (boundary pinned): None / Tangential (slides vertices in-surface) / Taubin (lambda-mu, no net shrink). Distributes strain / de-buckles. None suffices for near-developable inputs." />
                                        <ComboBox SelectedIndex="{Binding SmoothKind, Mode=TwoWay}" Height="20" FontSize="11" VerticalAlignment="Center" Margin="6,0">
                                            <ComboBoxItem Content="None" />
                                            <ComboBoxItem Content="Tangential" />
                                            <ComboBoxItem Content="Taubin" />
                                        </ComboBox>
                                    </DockPanel>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Smooth" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Smoother strength (only active when Smoother is not None)." />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding SmoothStrength, StringFormat=0.##}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="1" Value="{Binding SmoothStrength}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="DISPLAY">
                            <StackPanel Margin="10,12,10,0">
                                <TextBlock Text="SHADING" Foreground="#7A7A88" FontSize="10" FontWeight="Bold" Margin="2,0,0,6" />
                                <DockPanel Margin="0,3,0,0">
                                    <TextBlock DockPanel.Dock="Left" Text="Facet" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                               ToolTip="0% = smooth (averaged normals) · 100% = faceted (per-face). Shader-blended, live." />
                                    <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding Facet, Converter={StaticResource FractionToPercent}}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                    <Slider Minimum="0" Maximum="1" Value="{Binding Facet}" VerticalAlignment="Center" Margin="6,0" />
                                </DockPanel>
                                <DockPanel Margin="0,3,0,0">
                                    <TextBlock DockPanel.Dock="Left" Text="Curve" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                               ToolTip="Facet response exponent: blend = Facet^Curve. 1 = linear; higher keeps facets soft until high Facet, then sharpens." />
                                    <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding FacetExp, StringFormat=0.#}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                    <Slider Minimum="1" Maximum="30" Value="{Binding FacetExp}" VerticalAlignment="Center" Margin="6,0" />
                                </DockPanel>

                                <TextBlock Text="MATCAP" Foreground="#7A7A88" FontSize="10" FontWeight="Bold" Margin="2,16,0,6" />
                                <ListBox x:Name="MatcapList" Background="Transparent" BorderThickness="0" Padding="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="bd" BorderThickness="2" BorderBrush="Transparent" CornerRadius="3" Margin="3">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="BorderBrush" Value="#4A5A70" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="bd" Property="BorderBrush" Value="#6A9FE0" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding}" Width="46" Height="46" Stretch="UniformToFill" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <!-- BOTTOM bar (full width, 32px): live perf/status readout. Session transport is in the Console. -->
        <Border Grid.Row="3" Background="#2D2D30">
            <DockPanel Margin="8,0">
                <TextBlock x:Name="StatusText" DockPanel.Dock="Right" Text="" Foreground="#8A8A98"
                           VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
