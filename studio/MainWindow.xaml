<Window x:Class="CreaseStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CreaseStudio" Height="700" Width="1000"
        Background="#1E1E1E">
    <Window.Resources>
        <!-- sidebar-collapse glyph (from sidebar-collapse.svg, 800x800); evenodd (F0). Mirrored
             with ScaleX=-1 for the right panel. -->
        <!-- Dark, flat tab headers (the default WPF TabItem renders light/3D, clashing with the
             hand-styled dark panels). Implicit style -> applies to every TabItem in the window. -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#8A8A98" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="hdr" Padding="9,4" Margin="0,0,2,0" Background="Transparent"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="hdr" Property="BorderBrush" Value="#6A9FE0" />
                                <Setter Property="Foreground" Value="#E0E0E8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C8C8D0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

