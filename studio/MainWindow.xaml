<Window x:Class="CreaseStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CreaseStudio"
        Title="CreaseStudio" Height="700" Width="1000"
        Background="#1E1E1E">
    <Window.Resources>
        <!-- Reusable: remaps a slider's value within [min,max] to a 0-100% readout. -->
        <local:RangeToPercentConverter x:Key="RangeToPercent" />
        <!-- Shows a fraction directly as a percent (value × 100), allowing >100% (e.g. deCraze to 300%). -->
        <local:FractionToPercentConverter x:Key="FractionToPercent" />
        <!-- sidebar-collapse glyph (from sidebar-collapse.svg, 800x800); evenodd (F0). Mirrored
             with ScaleX=-1 for the right panel. -->
        <!-- Dark, flat tab headers (the default WPF TabItem renders light/3D, clashing with the
             hand-styled dark panels). Implicit style -> applies to every TabItem in the window. -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#8A8A98" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="hdr" Padding="9,4" Margin="0,0,2,0" Background="Transparent"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="hdr" Property="BorderBrush" Value="#6A9FE0" />
                                <Setter Property="Foreground" Value="#E0E0E8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C8C8D0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark menu items (the default WPF menu renders light, clashing with the dark chrome). -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#C8C8C8" />
            <Setter Property="Background" Value="#2D2D30" />
        </Style>

        <Geometry x:Key="CollapseIcon">F0 m375.35 316.42l-82.33 82.33 82.33 82.34c4.97 4.62 7.84 11.06 7.96 17.85 0.12 6.78-2.52 13.32-7.32 18.11-4.8 4.8-11.34 7.44-18.12 7.32-6.78-0.12-13.22-2.99-17.85-7.95l-100-100c-2.32-2.32-4.16-5.08-5.41-8.11-1.25-3.03-1.9-6.28-1.9-9.56 0-3.28 0.65-6.53 1.9-9.56 1.25-3.03 3.09-5.78 5.41-8.1l100-100c4.74-4.42 11.01-6.82 17.49-6.71 6.47 0.11 12.65 2.74 17.23 7.32 4.58 4.58 7.21 10.76 7.32 17.24 0.11 6.47-2.29 12.74-6.71 17.48z m125 66.67c-7.66 0-15.25 1.51-22.32 4.44-7.08 2.93-13.51 7.23-18.93 12.64-5.41 5.42-9.71 11.85-12.64 18.93-2.93 7.07-4.44 14.66-4.44 22.32v550c0 32.2 26.13 58.33 58.33 58.33h550c7.66 0 15.25-1.51 22.32-4.44 7.08-2.93 13.51-7.23 18.93-12.64 5.41-5.42 9.71-11.85 12.64-18.93 2.93-7.07 4.44-14.66 4.44-22.32v-550c0-7.66-1.51-15.25-4.44-22.32-2.93-7.08-7.23-13.51-12.64-18.93-5.42-5.41-11.85-9.71-18.93-12.64-7.07-2.93-14.66-4.44-22.32-4.44zm-8.33 58.33q0-1.66 0.63-3.19 0.64-1.53 1.81-2.7 1.17-1.17 2.7-1.81 1.53-0.63 3.19-0.63h375v566.66h-375q-1.66 0-3.19-0.63-1.53-0.64-2.7-1.81-1.17-1.17-1.81-2.7-0.63-1.53-0.63-3.19zm433.33 558.33v-566.66h125q1.66 0 3.19 0.63 1.53 0.64 2.7 1.81 1.17 1.17 1.81 2.7 0.63 1.53 0.63 3.19v550q0 1.66-0.63 3.19-0.64 1.53-1.81 2.7-1.17 1.17-2.7 1.81-1.53 0.63-3.19 0.63z</Geometry>
    </Window.Resources>
    <!-- Standard 4-panel docked chrome: Windows-style menu bar, fixed top/bottom bars, drag-resizable
         + collapsible left/right panels (chevron + drag-below-32px), center hosts the GL viewport. -->
    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="64" />
        </Grid.RowDefinitions>

        <!-- MENU bar (Windows-style). Shortcuts shown via InputGestureText are bound in code-behind. -->
        <Menu Grid.Row="0" Background="#2D2D30" Foreground="#C8C8C8" Padding="2,1">
            <MenuItem Header="_File">
                <MenuItem x:Name="MenuSaveAs" Header="Save Session _As…" InputGestureText="Ctrl+S" />
            </MenuItem>
            <MenuItem Header="_Window">
                <MenuItem x:Name="MenuConsole" Header="_Console" IsCheckable="True" InputGestureText="Ctrl+Shift+J" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem x:Name="MenuAbout" Header="_About" />
            </MenuItem>
        </Menu>

        <!-- TOP bar (full width, 32px) -->
        <Border Grid.Row="1" Background="#2D2D30">
            <DockPanel LastChildFill="False" Margin="8,0">
                <TextBlock DockPanel.Dock="Left" Text="CreaseStudio" Foreground="#C8C8C8"
                           VerticalAlignment="Center" FontSize="12" />
                <!-- Right-docked: first declared sits rightmost. Layout L->R: Reset | SubD | +N iter. -->
                <Button x:Name="IterButton" DockPanel.Dock="Right" Content="{Binding IterLabel}"
                        Padding="12,2" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center" />
                <Button x:Name="SubdivideButton" DockPanel.Dock="Right" Content="SubD"
                        Padding="10,2" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center"
                        ToolTip="One 1-to-4 subdivision (refine, then keep flowing)" />
                <Button x:Name="ResetButton" DockPanel.Dock="Right" Content="Reset"
                        Padding="10,2" FontSize="12" VerticalAlignment="Center"
                        ToolTip="Reload the input mesh and reset the flow" />
            </DockPanel>
        </Border>

        <!-- MIDDLE row: left panel | splitter | center | splitter | right panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftCol" Width="220" MinWidth="26" />
                <ColumnDefinition x:Name="LeftSplitCol" Width="6" />
                <ColumnDefinition Width="*" MinWidth="120" />
                <ColumnDefinition x:Name="RightSplitCol" Width="6" />
                <ColumnDefinition x:Name="RightCol" Width="240" MinWidth="26" />
            </Grid.ColumnDefinitions>

            <!-- LEFT panel: placeholder (the session log now lives in the toggleable Console window;
                 Window > Console or Ctrl+Shift+J). Collapse chevron at the top-RIGHT (inner) corner. -->
            <Border Grid.Column="0" Background="#252526" ClipToBounds="True">
                <Grid>
                    <Button x:Name="LeftCollapseBtn" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Width="24" Height="24" Margin="0,4,4,0" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" ToolTip="Collapse / expand panel">
                        <Viewbox Width="15" Height="15">
                            <Path Data="{StaticResource CollapseIcon}" Fill="#A0A6AE" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <!-- LEFT splitter (drag to resize, click to collapse/expand) -->
            <GridSplitter x:Name="LeftSplitter" Grid.Column="1" Width="6"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#3F3F46" ShowsPreview="False"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" />

            <!-- CENTER region: GL viewport gets injected here in code-behind -->
            <Grid x:Name="CenterHost" Grid.Column="2" Background="#1A1A1C" ClipToBounds="True" />

            <!-- RIGHT splitter (drag to resize, click to collapse/expand) -->
            <GridSplitter x:Name="RightSplitter" Grid.Column="3" Width="6"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#3F3F46" ShowsPreview="False"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" />

            <!-- RIGHT panel: SIMULATION / DISPLAY tabs (bound to SimSettings view-model). Collapse
                 chevron sits in its own thin strip at the top-LEFT (inner) corner, icon mirrored;
                 the tab strip + content fill the rest. -->
            <Border Grid.Column="4" Background="#2A2A2E" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- chevron strip -->
                    <Button x:Name="RightCollapseBtn" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top"
                            Width="24" Height="24" Margin="4,2,0,0" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" ToolTip="Collapse / expand panel">
                        <Viewbox Width="15" Height="15">
                            <Path Data="{StaticResource CollapseIcon}" Fill="#A0A6AE"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleX="-1" />
                                </Path.RenderTransform>
                            </Path>
                        </Viewbox>
                    </Button>

                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0">
                        <TabItem Header="SIMULATION">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,8">
                                <StackPanel Margin="10,0,10,0">
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Iter / run" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding IterPerRun}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="1" Maximum="100" Value="{Binding IterPerRun}" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Step" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource RangeToPercent}">
                                                    <Binding Path="Value" ElementName="StepSlider" />
                                                    <Binding Path="Minimum" ElementName="StepSlider" />
                                                    <Binding Path="Maximum" ElementName="StepSlider" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Slider x:Name="StepSlider" Minimum="0.001" Maximum="0.05" Value="{Binding Step}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Momentum" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding Momentum, StringFormat=0.##}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="0.95" Value="{Binding Momentum}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="deCraze" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding DeCraze, Converter={StaticResource FractionToPercent}}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="3" Value="{Binding DeCraze}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="CrazeBand" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding CrazeBandDeg, StringFormat={}{0:0.#}°}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="30" Value="{Binding CrazeBandDeg}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Sharpness" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding Sharpness, StringFormat=0.#}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="8" Value="{Binding Sharpness}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="DetMix" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding DetMix, StringFormat=0.##}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="1" Value="{Binding DetMix}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="MomFix" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding MomFix}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="1" Maximum="4" Value="{Binding MomFix}" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="DISPLAY">
                            <StackPanel Margin="10,12,10,0">
                                <TextBlock Text="SHADING" Foreground="#7A7A88" FontSize="10" FontWeight="Bold" Margin="2,0,0,6" />
                                <DockPanel Margin="0,3,0,0">
                                    <TextBlock DockPanel.Dock="Left" Text="Facet" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                               ToolTip="0% = smooth (averaged normals) · 100% = faceted (per-face). Shader-blended, live." />
                                    <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding Facet, Converter={StaticResource FractionToPercent}}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                    <Slider Minimum="0" Maximum="1" Value="{Binding Facet}" VerticalAlignment="Center" Margin="6,0" />
                                </DockPanel>
                                <DockPanel Margin="0,3,0,0">
                                    <TextBlock DockPanel.Dock="Left" Text="Curve" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                               ToolTip="Facet response exponent: blend = Facet^Curve. 1 = linear; higher keeps facets soft until high Facet, then sharpens." />
                                    <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding FacetExp, StringFormat=0.#}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                    <Slider Minimum="1" Maximum="30" Value="{Binding FacetExp}" VerticalAlignment="Center" Margin="6,0" />
                                </DockPanel>

                                <TextBlock Text="MATCAP" Foreground="#7A7A88" FontSize="10" FontWeight="Bold" Margin="2,16,0,6" />
                                <ListBox x:Name="MatcapList" Background="Transparent" BorderThickness="0" Padding="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="bd" BorderThickness="2" BorderBrush="Transparent" CornerRadius="3" Margin="3">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="BorderBrush" Value="#4A5A70" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="bd" Property="BorderBrush" Value="#6A9FE0" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding}" Width="46" Height="46" Stretch="UniformToFill" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="BRUSH">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,8">
                                <StackPanel Margin="10,0,10,0">
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Strength" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center"
                                                   ToolTip="Buff: developability iterations per stroke (K). Noise: amplitude." />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding BrushStrength, StringFormat=0}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider Minimum="1" Maximum="60" Value="{Binding BrushStrength}" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Speed" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" ToolTip="Flow — passes over a spot to reach full strength" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource RangeToPercent}">
                                                    <Binding Path="Value" ElementName="FlowSlider" />
                                                    <Binding Path="Minimum" ElementName="FlowSlider" />
                                                    <Binding Path="Maximum" ElementName="FlowSlider" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Slider x:Name="FlowSlider" Minimum="0" Maximum="1" Value="{Binding BrushFlow}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Size" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" ToolTip="Footprint radius (world units) — also [ / ]" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Text="{Binding BrushSize, StringFormat=0.#}" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center" />
                                        <Slider x:Name="BrushSizeSlider" Minimum="1" Maximum="100" Value="{Binding BrushSize}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>

                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Softness" Width="62" Foreground="#C8C8C8" FontSize="11" VerticalAlignment="Center" ToolTip="Gaussian falloff — also Ctrl+Shift+[ / ]" />
                                        <TextBlock DockPanel.Dock="Right" Width="40" Foreground="#8A8A98" FontSize="11" TextAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource RangeToPercent}">
                                                    <Binding Path="Value" ElementName="SoftnessSlider" />
                                                    <Binding Path="Minimum" ElementName="SoftnessSlider" />
                                                    <Binding Path="Maximum" ElementName="SoftnessSlider" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Slider x:Name="SoftnessSlider" Minimum="0" Maximum="1" Value="{Binding BrushSoftness}" VerticalAlignment="Center" Margin="6,0" />
                                    </DockPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <!-- BOTTOM bar (full width, 64px): brushes (square tiles, word inside). Live perf/status
             readout on the right. Session transport lives in the Console window. -->
        <Border Grid.Row="3" Background="#2D2D30">
            <DockPanel Margin="8,0" LastChildFill="False">
                <ToggleButton x:Name="NoiseBrushButton" DockPanel.Dock="Left" Content="NOISE"
                              Width="54" Height="48" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"
                              ToolTip="NOISE — ± normal Perlin displacement. Left-drag paints. [ ] size, Ctrl+Shift+[ ] soften/harden." />
                <ToggleButton x:Name="CreaseBrushButton" DockPanel.Dock="Left" Content="CREASE"
                              Width="54" Height="48" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"
                              ToolTip="CREASE — carves an inward valley/fold line to seed a panel boundary (Softness = width). [prototype]" />
                <ToggleButton x:Name="FlattenBrushButton" DockPanel.Dock="Left" Content="FLATTEN"
                              Width="54" Height="48" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"
                              ToolTip="FLATTEN — presses the area onto the plane you start the stroke on -> a clean flat panel. [prototype]" />
                <ToggleButton x:Name="SmoothBrushButton" DockPanel.Dock="Left" Content="SMOOTH"
                              Width="54" Height="48" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"
                              ToolTip="SMOOTH — Laplacian relax toward the neighbour average: denoise / soften wrinkles. [prototype]" />
                <ToggleButton x:Name="PolishBrushButton" DockPanel.Dock="Left" Content="POLISH"
                              Width="54" Height="48" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"
                              ToolTip="POLISH — developability flow with crease-preserving deCraze (Huber band): cleans panels, keeps sharp creases." />
                <ToggleButton x:Name="BuffBrushButton" DockPanel.Dock="Left" Content="BUFF"
                              Width="54" Height="48" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"
                              ToolTip="BUFF — same deCraze flow but with no Huber band (pure L1): rounds / softens creases." />
                <ToggleButton x:Name="SharpenBrushButton" DockPanel.Dock="Left" Content="SHARPEN"
                              Width="54" Height="48" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"
                              ToolTip="SHARPEN — developability burst with max-covariance: forces straighter rulings / clearer panel structure. [prototype]" />
                <TextBlock x:Name="StatusText" DockPanel.Dock="Right" Text="" Foreground="#8A8A98"
                           VerticalAlignment="Center" FontSize="11" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
